programa {
  funcao inicio() {
  
  inteiro opcao
escreva("Por favor, informe um número entre 1 e 4:\n")
leia(opcao)
escolha(opcao)
{caso 1:
escreva("Você escolheu a opção 1\n")
pare
caso 2:
escreva("Você escolheu a opção 2\n")
pare
caso 3:
escreva("Você escolheu a opção 3\n")
pare
caso 4:
escreva("Você escolheu a opção 4\n")
pare
caso contrario:
 escreva("Opção inválida!\n")
}
 }
}


