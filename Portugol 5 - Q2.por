programa {
  funcao inicio() {
  inteiro opcao
   

escreva("Escolha uma opção:\n")
escreva("1 - Olá\n")
escreva("2 - Tchau\n")
escreva("3 - Sair\n")
leia(opcao)

 escolha (opcao)
{
caso 1:
escreva("Olá, tudo bem?\n")
 pare

caso 2:
escreva("Tchau, até mais!\n")
pare

caso 3:
escreva("Saindo do programa...\n")
pare

caso contrario:
escreva("Opção inválida!\n")
}
}
}




  


